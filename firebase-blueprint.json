{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core user profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "agent", "member"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "circle": { "type": "string" },
        "ubtBalance": { "type": "number" },
        "publicKey": { "type": "string" },
        "recoveryCommitment": { "type": "string" },
        "isKeyRotated": { "type": "boolean" }
      },
      "required": ["name", "email", "role", "status"]
    },
    "Post": {
      "title": "Post",
      "description": "Social feed post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "types": { "type": "string" }
      },
      "required": ["authorId", "content", "date"]
    },
    "Simulation": {
      "title": "Simulation",
      "description": "Market simulation instance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "seedMaterial": { "type": "string" },
        "status": { "type": "string" },
        "confidenceScore": { "type": "number" },
        "agentCount": { "type": "number" }
      },
      "required": ["userId", "title", "seedMaterial", "status"]
    },
    "SimAgent": {
      "title": "SimAgent",
      "description": "AI agent in a simulation",
      "type": "object",
      "properties": {
        "simulationId": { "type": "string" },
        "name": { "type": "string" },
        "persona": { "type": "string" }
      },
      "required": ["simulationId", "name", "persona"]
    },
    "SimMessage": {
      "title": "SimMessage",
      "description": "Message generated by an agent",
      "type": "object",
      "properties": {
        "simulationId": { "type": "string" },
        "agentId": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["simulationId", "agentId", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social posts"
    },
    "/simulations/{simId}": {
      "schema": "Simulation",
      "description": "Market simulations"
    },
    "/simulations/{simId}/agents/{agentId}": {
      "schema": "SimAgent",
      "description": "Agents in simulation"
    },
    "/simulations/{simId}/messages/{msgId}": {
      "schema": "SimMessage",
      "description": "Messages in simulation"
    }
  }
}
