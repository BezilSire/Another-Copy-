rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }
    function isGuest() { return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous'; }
    function isMember() { return isSignedIn() && !isGuest(); }
    
    // Improved robust Admin check
    function isAdmin() { 
      return isSignedIn() && 
             ((request.auth.token.email == "bezilsire00@gmail.com" || request.auth.token.email == "bezilsire01@gmail.com") && 
              request.auth.token.email_verified == true); 
    }
    
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // --- IDENTITY & WALLETS ---
    match /users/{userId} {
      allow get: if true; 
      allow read, list: if isSignedIn(); 
      allow create: if isMember() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      
      match /private/data {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }

      match /notifications/{id} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /transactions/{id} { allow read, list: if isOwner(userId) || isAdmin(); allow create: if isMember(); }
      match /vaults/{id} { allow read, write, list: if isOwner(userId) || isAdmin(); }
    }

    // --- GOVERNANCE ---
    match /candidates/{candidateId} {
      allow read, list: if true; 
      allow create: if isMember();
      allow update: if isMember() && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'voteCount', 'status']));
      allow delete: if isAdmin() || (isMember() && resource.data.userId == request.auth.uid);
    }

    // --- TREASURY & LEDGER ---
    match /treasury_vaults/{vaultId} {
      allow read, list: if isSignedIn(); 
      allow write, update, delete: if isAdmin();
    }
    match /ledger/{docId} {
      allow read, list: if true; 
      allow create: if isMember() || isAdmin();
      allow write, update: if isAdmin();
    }
    match /globals/{docId} {
      allow read: if true; 
      allow write, update: if isAdmin();
    }
    match /multisig_proposals/{id} {
      allow read, list: if isSignedIn(); 
      allow write, update: if isAdmin();
    }

    // --- BRIDGE / ORACLE ---
    match /pending_ubt_purchases/{docId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isMember() || isAdmin();
      allow update, delete: if isAdmin();
    }

    // --- COMMUNITY ---
    match /posts/{postId} {
      allow read, list: if isSignedIn();
      allow create: if isMember();
      allow update: if isMember() && (resource.data.authorId == request.auth.uid || isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'repostCount', 'commentCount', 'isPinned', 'content']));
      allow delete: if isAdmin() || (isMember() && resource.data.authorId == request.auth.uid);
      
      match /comments/{id} { allow read, list: if isSignedIn(); allow write: if isMember(); }
    }
    
    // --- ECOSYSTEM MODULES ---
    match /members/{id} { 
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid); 
      allow create: if isMember() || isAdmin(); 
      allow update: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin(); 
    }
    
    match /proposals/{id} { allow read, list: if isSignedIn(); allow create, update: if isMember() || isAdmin(); }
    match /ventures/{id} { allow read, list: if isSignedIn(); allow create: if isMember() || isAdmin(); allow update: if (isMember() && resource.data.ownerId == request.auth.uid) || isAdmin(); allow delete: if isAdmin() || (isMember() && resource.data.ownerId == request.auth.uid); match /distributions/{id} { allow read, list: if isSignedIn(); allow write: if isAdmin(); } }
    match /payouts/{id} { allow read, list: if isAdmin() || (isMember() && resource.data.userId == request.auth.uid); allow create: if isMember(); allow update: if isAdmin(); }
    match /broadcasts/{id} { allow read, list: if isSignedIn(); allow write: if isAdmin(); }
    match /price_verifications/{id} { allow read, list: if isAdmin(); allow create: if isMember(); }
    match /vouchers/{id} { allow read, list: if isMember() || isAdmin(); allow write: if isAdmin(); }
    match /activity/{id} { allow read, list: if isSignedIn(); allow write: if isMember() || isAdmin(); }
    match /reports/{id} { allow read, list: if isAdmin() || isMember(); allow write: if isMember() || isAdmin(); }
    match /vouches/{id} { allow read, list: if isSignedIn(); allow write: if isMember() || isAdmin(); }
    match /resources/{id} { allow read, list: if isSignedIn(); allow write: if isAdmin(); }
    match /disputes/{id} { allow read, list: if isSignedIn(); allow write: if isMember() || isAdmin(); }

    // --- SIMULATIONS ---
    match /simulations/{simId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || request.query.filters.userId == request.auth.uid || isAdmin());
      allow create: if isMember();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      match /agents/{agentId} {
        allow read, list: if isSignedIn();
        allow write: if isMember() || isAdmin();
      }

      match /messages/{msgId} {
        allow read, list: if isSignedIn();
        allow write: if isMember() || isAdmin();
      }
    }

    // --- BLOCKCHAIN DATA ---
    match /blocks/{id} {
      allow read, list: if true; 
      allow write: if isAdmin();
    }
    match /mempool/{id} {
      allow read, list: if isSignedIn();
      allow write: if isMember() || isAdmin();
    }

    // --- DISTRESS CALLS ---
    match /distress_calls/{callId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isMember();
      allow update: if isAdmin();
    }

    // --- WHATSAPP & ZIM PULSE ---
    match /whatsapp_sessions/{sessionId} {
      allow read, write: if isAdmin();
      match /keys/{keyId} { allow read, write: if isAdmin(); }
    }
    match /zim_pulse/{docId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}